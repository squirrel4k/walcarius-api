{
  "name": "walcarius-back",
  "version": "0.0.1",
  "description": "walcarius backend",
  "author": "ITDM",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:dev": "nodemon",
    "start:debug": "nodemon --config nodemon-debug.json",
    "prestart:prod": "rimraf dist && npm run build",
    "start:prod": "node dist/main.js",
    "lint": "tslint -p tsconfig.json -c tslint.json",
    "cache:sync": "typeorm schema:sync",
    "cache:clear": "typeorm cache:clear",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "compodoc": "npx compodoc -p tsconfig.doc.json"
  },
  "dependencies": {
    "@nestjs/common": "5.4.0",
    "@nestjs/core": "5.4.0",
    "@nestjs/graphql": "5.5.7",
    "@nestjs/jwt": "0.3.0",
    "@nestjs/microservices": "5.7.3",
    "@nestjs/mongoose": "5.2.2",
    "@nestjs/passport": "5.1.0",
    "@nestjs/typeorm": "5.3.0",
    "apollo-server-express": "2.4.8",
    "bcrypt": "3.0.4",
    "body-parser": "1.19.0",
    "class-transformer": "0.2.0",
    "class-validator": "0.9.1",
    "cors": "2.8.5",
    "dataloader": "1.4.0",
    "dotenv": "6.2.0",
    "ejs": "2.6.1",
    "email-templates": "5.0.4",
    "express": "4.16.4",
    "graphql": "14.1.1",
    "graphql-extensions": "0.5.7",
    "graphql-tools": "4.0.4",
    "graphql-type-json": "0.2.1",
    "mime-types": "2.1.22",
    "mongoose": "5.4.17",
    "mysql": "2.16.0",
    "node-localstorage": "^2.2.1",
    "nodemailer": "5.1.1",
    "passport": "0.4.0",
    "passport-jwt": "4.0.0",
    "puppeteer": "2.0.0",
    "reflect-metadata": "0.1.12",
    "rimraf": "2.6.2",
    "rxjs": "6.2.2",
    "ts-localstorage": "^2.0.0",
    "typeorm": "0.2.19",
    "typescript": "4.2.3",
    "uuid": "3.3.2",
    "winston": "3.2.1",
    "winston-daily-rotate-file": "4.2.1"
  },
  "devDependencies": {
    "@nestjs/testing": "5.1.0",
    "@types/cors": "2.8.4",
    "@types/email-templates": "3.5.1",
    "@types/express": "4.16.1",
    "@types/jest": "23.3.1",
    "@types/node": "10.7.1",
    "@types/puppeteer": "^1.20.2",
    "@types/supertest": "2.0.5",
    "jest": "23.5.0",
    "nodemon": "1.18.3",
    "prettier": "1.14.2",
    "supertest": "3.1.0",
    "ts-jest": "23.1.3",
    "ts-loader": "4.4.2",
    "ts-node": "7.0.1",
    "tsconfig-paths": "3.5.0",
    "tslint": "5.11.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
